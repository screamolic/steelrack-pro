rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
       allow read, write: if false; 
    }

    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidPlan(data) {
       return data.keys().hasAll(['name', 'mode', 'unit', 'inputs', 'createdAt', 'expiresAt']) 
         && data.name is string && data.name.size() > 0 && data.name.size() <= 100
         && data.mode is string && data.mode.size() <= 20
         && data.unit is string && data.unit.size() <= 10
         && data.inputs is map 
         && data.createdAt == request.time
         && data.expiresAt is timestamp
         && data.expiresAt > request.time;
    }

    match /plans/{planId} {
       allow get: if isValidId(planId) && existing().expiresAt > request.time;
       allow create: if isValidId(planId) && isValidPlan(incoming());
       allow update, delete: if false;
    }
  }
}    
